# Credenciais do Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token_aqui
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Configurações da aplicação
FLASK_ENV=development
PORT=5000

# Nome da empresa exibido nas mensagens do bot
NOME_EMPRESA=Minha Empresa

# Horário comercial para agendamento de reuniões (formato 24h)
HORARIO_ABERTURA=09:00
HORARIO_FECHAMENTO=18:00

# Duração padrão das reuniões, em minutos
DURACAO_REUNIAO_MIN=60

# Lembretes via pywhatkit (requer WhatsApp Web logado no navegador da máquina)
# Deixe como "false" em servidores sem interface gráfica
LEMBRETES_ATIVOS=false
# Quantos minutos antes da reunião o lembrete deve ser enviado
LEMBRETE_ANTECEDENCIA_MIN=30
